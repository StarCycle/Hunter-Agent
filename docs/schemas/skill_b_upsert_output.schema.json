{
  "$defs": {
    "ContactItem": {
      "properties": {
        "type": {
          "enum": [
            "wechat",
            "phone",
            "email"
          ],
          "title": "Type",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        },
        "verified": {
          "title": "Verified",
          "type": "integer"
        },
        "created_at": {
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "type",
        "value",
        "verified",
        "created_at",
        "updated_at"
      ],
      "title": "ContactItem",
      "type": "object"
    },
    "DedupResult": {
      "properties": {
        "candidate_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "score": {
          "title": "Score",
          "type": "integer"
        },
        "conflict": {
          "title": "Conflict",
          "type": "boolean"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "forced_insert": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Forced Insert"
        }
      },
      "required": [
        "score",
        "conflict"
      ],
      "title": "DedupResult",
      "type": "object"
    },
    "ProjectTagItem": {
      "properties": {
        "category": {
          "title": "Category",
          "type": "string"
        },
        "other_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Other Text"
        },
        "created_at": {
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "category",
        "created_at"
      ],
      "title": "ProjectTagItem",
      "type": "object"
    },
    "TalentCore": {
      "properties": {
        "id": {
