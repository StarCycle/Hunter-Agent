          "type": "integer"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "normalized_name": {
          "title": "Normalized Name",
          "type": "string"
        },
        "education": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Education"
        },
        "institution": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Institution"
        },
        "grade_or_years": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Grade Or Years"
        },
        "resume_pdf": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resume Pdf"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "created_at": {
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "normalized_name",
        "created_at",
        "updated_at"
      ],
      "title": "TalentCore",
      "type": "object"
    },
    "TalentView": {
      "properties": {
        "talent": {
          "$ref": "#/$defs/TalentCore"
        },
        "contacts": {
          "items": {
            "$ref": "#/$defs/ContactItem"
          },
          "title": "Contacts",
          "type": "array"
        },
        "project_tags": {
          "items": {
            "$ref": "#/$defs/ProjectTagItem"
          },
          "title": "Project Tags",
          "type": "array"
        },
        "dedup": {
          "anyOf": [
            {
              "$ref": "#/$defs/DedupResult"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "operation": {
          "anyOf": [
            {
              "enum": [
                "insert",
                "update"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operation"
        }
      },
      "required": [
        "talent",
        "contacts",
        "project_tags"
      ],
      "title": "TalentView",
      "type": "object"
    }
  },
  "properties": {
    "action": {
      "const": "upsert",
      "default": "upsert",
      "title": "Action",
      "type": "string"
    },
    "profile": {
      "$ref": "#/$defs/TalentView"
    }
  },
  "required": [
    "profile"
  ],
  "title": "SkillBUpsertOutput",
  "type": "object"
}